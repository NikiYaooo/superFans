<Application x:Class="superFans.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <!-- Color Palette -->
        <SolidColorBrush x:Key="BgDark" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgCard" Color="#2D2D44"/>
        <SolidColorBrush x:Key="BgSidebar" Color="#16162A"/>
        <SolidColorBrush x:Key="AccentColor" Color="#6C63FF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#7E76FF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E0E0F0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8888A0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#5A5A72"/>
        <SolidColorBrush x:Key="GreenColor" Color="#4CAF50"/>
        <SolidColorBrush x:Key="YellowColor" Color="#FFC107"/>
        <SolidColorBrush x:Key="RedColor" Color="#F44336"/>
        <SolidColorBrush x:Key="SliderTrack" Color="#3D3D5C"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3A3A55"/>

        <!-- Slider Style (Dark) -->
        <Style TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="SmallChange" Value="1"/>
            <Setter Property="LargeChange" Value="10"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
        </Style>

        <!-- ToggleButton Style -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="SwitchBg" CornerRadius="14"
                                Background="{StaticResource SliderTrack}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb" Fill="#888"
                                     Width="22" Height="22"
                                     HorizontalAlignment="Left"
                                     Margin="2,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBg" Property="Background"
                                        Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Thumb" Property="Fill"
                                        Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                        Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin"
                                        Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchBg" Property="Opacity" Value="0.4"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Style (Accent) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHover}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A55"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
