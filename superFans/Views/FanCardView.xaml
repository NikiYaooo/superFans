<UserControl x:Class="superFans.Views.FanCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:superFans.Views"
             xmlns:converters="clr-namespace:superFans.Converters"
             FontFamily="Microsoft YaHei UI">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:TempColorConverter x:Key="TempColor"/>
    </UserControl.Resources>

    <Border Background="{StaticResource BgCard}"
            CornerRadius="10"
            Padding="20"
            Margin="0,0,12,12"
            MinHeight="200">

        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsControllable}" Value="False">
                        <Setter Property="Opacity" Value="0.7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Fan Name + Type Badge + Mode Toggle -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Name}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="240"/>
                    <Border Background="{StaticResource AccentColor}"
                            CornerRadius="4"
                            Padding="6,2"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0">
                        <TextBlock Text="{Binding TypeDisplay}"
                                   FontSize="10"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- Mode Toggle -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsControllable, Converter={StaticResource BoolToVis}}">
                    <ToggleButton Style="{StaticResource ToggleSwitch}"
                                  IsChecked="{Binding IsManualMode, Mode=OneWay}"
                                  Command="{Binding ToggleModeCommand}"/>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="10"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource TextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutoMode}" Value="True">
                                        <Setter Property="Text" Value="自动"/>
                                        <Setter Property="Foreground" Value="{StaticResource GreenColor}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsManualMode}" Value="True">
                                        <Setter Property="Text" Value="手动"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- ReadOnly Badge -->
                <Border Grid.Column="1"
                        Visibility="{Binding IsControllable, Converter={StaticResource InverseBool}}"
                        Background="#3D3520"
                        CornerRadius="4"
                        Padding="8,4"
                        VerticalAlignment="Center">
                    <TextBlock Text="只读"
                               FontSize="11"
                               Foreground="{StaticResource YellowColor}"/>
                </Border>
            </Grid>

            <!-- Row 1: RPM + Temp Gauges -->
            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- RPM -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="转速"
                               FontSize="10"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{Binding RpmDisplay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>

                <!-- Temperature -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="温度"
                               FontSize="10"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{Binding TempDisplay}"
                               FontSize="18" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AssociatedTempC}" Value="75">
                                        <Setter Property="Foreground" Value="{StaticResource RedColor}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <TextBlock.Foreground>
                            <Binding Path="AssociatedTempC" Converter="{StaticResource TempColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>

                <!-- Duty Cycle -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="占空比"
                               FontSize="10"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{Binding DutyDisplay}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentColor}"/>
                </StackPanel>
            </Grid>

            <!-- Row 2: Speed Slider -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Slider Grid.Column="0"
                        Value="{Binding TargetSpeed, Delay=50}"
                        IsEnabled="{Binding IsSliderEnabled}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                    <Slider.Style>
                        <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSliderEnabled}" Value="True">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource AccentColor}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSliderEnabled}" Value="False">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource TextMuted}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Slider.Style>
                </Slider>

                <TextBlock Grid.Column="1"
                           Text="{Binding TargetSpeedDisplay}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"
                           Width="50"
                           TextAlignment="Right"/>
            </Grid>

            <!-- Row 3: Speed Presets (quick buttons) -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Visibility="{Binding IsSliderEnabled, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,4">
                <Button Content="静音 20%" FontSize="10"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,3" Margin="0,0,4,0"
                        Click="QuickSpeed_Click" Tag="20"/>
                <Button Content="标准 50%" FontSize="10"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,3" Margin="0,0,4,0"
                        Click="QuickSpeed_Click" Tag="50"/>
                <Button Content="性能 75%" FontSize="10"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,3" Margin="0,0,4,0"
                        Click="QuickSpeed_Click" Tag="75"/>
                <Button Content="全速 100%" FontSize="10"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,3"
                        Click="QuickSpeed_Click" Tag="100"/>
            </StackPanel>

            <!-- Row 4: Auto Mode Info (shown when in auto) -->
            <TextBlock Grid.Row="4"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"
                       Visibility="{Binding IsAutoMode, Converter={StaticResource BoolToVis}}">
                <TextBlock.Text>
                    <MultiBinding StringFormat="智能调速：当前 {0:F0}°C → 目标 {1:F0}%">
                        <Binding Path="AssociatedTempC"/>
                        <Binding Path="DutyCycle"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
