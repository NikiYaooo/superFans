<Window x:Class="superFans.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:superFans"
        xmlns:vm="clr-namespace:superFans.ViewModels"
        xmlns:views="clr-namespace:superFans.Views"
        Title="SuperFans — 智能风扇控制"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:FanCardViewModel}">
            <views:FanCardView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Left Sidebar ===== -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource BgSidebar}">
            <StackPanel Margin="20,24">
                <!-- App Title -->
                <TextBlock Text="SuperFans"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource AccentColor}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="智能风扇控制系统"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,28"/>

                <!-- Stats -->
                <Border Background="{StaticResource BgCard}"
                        CornerRadius="8" Padding="14"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="设备统计" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                <TextBlock Text="总风扇"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding TotalFanCount}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                <TextBlock Text="可控"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding ControllableFanCount}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource GreenColor}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="只读"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding ReadOnlyFanCount}"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource YellowColor}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Global Controls -->
                <TextBlock Text="全局控制" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,10"/>

                <Button Content="全部自动模式"
                        Style="{StaticResource AccentButton}"
                        Margin="0,0,0,8"
                        Command="{Binding SetAllAutoCommand}"/>

                <Button Content="全部手动模式"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,8"
                        Command="{Binding SetAllManualCommand}"/>

                <!-- Safety Info -->
                <Border Background="#2D1F1F"
                        CornerRadius="6" Padding="12"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="🛡 安全保护" FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource RedColor}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="• 最低 20% 转速保护"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="• 85°C 强制满速"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="• 退出自动交还控制"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ===== Main Fan Cards Area ===== -->
        <ScrollViewer Grid.Row="0" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BgDark}">
            <ItemsControl ItemsSource="{Binding Fans}"
                          Margin="20,24"
                          x:Name="FanCardsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                   ItemWidth="380"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== Bottom Status Bar ===== -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Foreground="{StaticResource AccentColor}"
                           FontSize="11" FontWeight="SemiBold"
                           Text="SUPERFANS"/>

                <TextBlock Grid.Column="1"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="12,0,0,0"
                           Text="{Binding StatusText}"/>

                <TextBlock Grid.Column="2"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10"
                           Text="v1.0 | 数据刷新: 1s"/>
            </Grid>
        </Border>
    </Grid>
</Window>
